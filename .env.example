# =============================================================================
# Forense AI — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# =============================================================================

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://forense_app:dev_only_password@localhost:5432/forense_ai
DATABASE_URL_SYNC=postgresql://forense_app:dev_only_password@localhost:5432/forense_ai

# ── Security ──────────────────────────────────────────────────────────────────
# JWT signing key — generate with: openssl rand -hex 32
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Audit log HMAC key (separate from JWT key)
# Generate with: openssl rand -hex 32
AUDIT_HMAC_KEY=change_me_separate_hmac_key_for_audit_log

# Fernet key for encrypting MFA secrets at rest
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change_me_fernet_key_base64url_32bytes=

# itsdangerous key for password recovery tokens (separate from JWT key)
# Generate with: openssl rand -hex 32
RECOVERY_SECRET_KEY=change_me_recovery_secret_key
RECOVERY_TOKEN_EXPIRE_SECONDS=3600

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
